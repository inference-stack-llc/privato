# Optional for the reliable seeded demo; required for PostgreSQL persistence.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/privato

# 32-byte key encoded as 64 hexadecimal characters. Generate with: openssl rand -hex 32
PRIVATO_MASTER_KEY=

# Required for real Ask Privato answers. Without a key, Ask returns its designed unavailable state;
# only the document-extraction demo retains a clearly labeled deterministic fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Demo-only session signing secret. Use a long random value outside local development.
DEMO_SESSION_SECRET=
